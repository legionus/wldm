<?xml version="1.0" encoding="UTF-8"?>
<interface>
	<requires lib="gtk" version="4.0"/>

	<object class="GtkApplicationWindow" id="main_window">
		<property name="title">wldm</property>
		<property name="default-width">1280</property>
		<property name="default-height">720</property>
		<style>
			<class name="main-window"/>
		</style>

		<child>
			<object class="GtkBox" id="root_box">
				<property name="orientation">horizontal</property>
				<property name="hexpand">true</property>
				<property name="vexpand">true</property>

				<child>
					<!-- Left informational pane -->
					<object class="GtkBox" id="info_pane">
						<property name="orientation">vertical</property>
						<property name="hexpand">true</property>
						<property name="vexpand">true</property>
						<property name="spacing">10</property>
						<property name="margin-top">72</property>
						<property name="margin-bottom">72</property>
						<property name="margin-start">72</property>
						<property name="margin-end">36</property>
						<style>
							<class name="info-pane"/>
						</style>

						<child>
							<object class="GtkLabel" id="date_label">
								<property name="xalign">0</property>
								<style>
									<class name="date-label"/>
								</style>
							</object>
						</child>

						<child>
							<object class="GtkLabel" id="time_label">
								<property name="xalign">0</property>
								<style>
									<class name="time-label"/>
								</style>
							</object>
						</child>

						<child>
							<object class="GtkSeparator">
								<property name="margin-top">18</property>
								<property name="margin-bottom">18</property>
							</object>
						</child>

						<child>
							<object class="GtkLabel">
								<property name="label" translatable="yes">Wayland Display Manager</property>
								<property name="xalign">0</property>
								<style>
									<class name="eyebrow-label"/>
								</style>
							</object>
						</child>

						<child>
							<object class="GtkLabel">
								<property name="label" translatable="yes">Sign in to start a desktop session</property>
								<property name="wrap">true</property>
								<property name="max-width-chars">26</property>
								<property name="xalign">0</property>
								<style>
									<class name="headline-label"/>
								</style>
							</object>
						</child>

						<child>
							<object class="GtkLabel" id="hostname_label">
								<property name="xalign">0</property>
								<style>
									<class name="hostname-label"/>
								</style>
							</object>
						</child>
					</object>
				</child>

				<child>
					<!-- Right authentication pane -->
					<object class="GtkBox" id="content_pane">
						<property name="orientation">vertical</property>
						<property name="halign">fill</property>
						<property name="valign">fill</property>
						<property name="hexpand">true</property>
						<property name="vexpand">true</property>
						<property name="margin-top">48</property>
						<property name="margin-bottom">48</property>
						<property name="margin-start">36</property>
						<property name="margin-end">72</property>
						<property name="spacing">24</property>

						<child>
							<object class="GtkBox" id="login_card_outer">
								<property name="orientation">vertical</property>
								<property name="halign">center</property>
								<property name="valign">center</property>
								<property name="hexpand">true</property>
								<property name="vexpand">true</property>

								<child>
									<object class="GtkBox" id="login_card">
										<property name="orientation">vertical</property>
										<property name="spacing">16</property>
										<property name="width-request">420</property>
										<style>
											<class name="login-card"/>
										</style>

										<child>
											<object class="GtkLabel">
												<property name="label" translatable="yes">Welcome back</property>
												<property name="xalign">0</property>
												<style>
													<class name="card-title"/>
												</style>
											</object>
										</child>

										<child>
											<object class="GtkBox" id="identity_preview">
												<property name="orientation">horizontal</property>
												<property name="spacing">12</property>

												<child>
													<object class="GtkLabel" id="avatar_label">
														<property name="label">?</property>
														<property name="justify">center</property>
														<style>
															<class name="avatar-label"/>
														</style>
													</object>
												</child>

												<child>
													<object class="GtkLabel" id="identity_label">
														<property name="wrap">true</property>
														<property name="hexpand">true</property>
														<property name="max-width-chars">28</property>
														<property name="width-chars">28</property>
														<property name="xalign">0</property>
														<style>
															<class name="identity-label"/>
														</style>
													</object>
												</child>
											</object>
										</child>

										<child>
											<object class="GtkEntry" id="username_entry">
												<property name="placeholder-text" translatable="yes">Username</property>
												<property name="hexpand">true</property>
												<style>
													<class name="greeter-entry"/>
												</style>
											</object>
										</child>

										<child>
											<object class="GtkPasswordEntry" id="password_entry">
												<property name="placeholder-text" translatable="yes">Password</property>
												<property name="show-peek-icon">true</property>
												<property name="hexpand">true</property>
												<style>
													<class name="greeter-entry"/>
												</style>
											</object>
										</child>

										<child>
											<object class="GtkDropDown" id="sessions_entry">
												<property name="hexpand">true</property>
												<style>
													<class name="session-picker"/>
												</style>
											</object>
										</child>

										<child>
											<object class="GtkBox" id="auth_actions">
												<property name="orientation">horizontal</property>
												<property name="spacing">10</property>

												<child>
													<object class="GtkButton" id="login_button">
														<property name="label" translatable="yes">Sign in</property>
														<property name="hexpand">true</property>
														<style>
															<class name="primary-button"/>
														</style>
													</object>
												</child>

												<child>
													<object class="GtkButton" id="cancel_button">
														<property name="label">✕</property>
														<property name="tooltip-text" translatable="yes">Cancel</property>
														<property name="visible">false</property>
														<style>
															<class name="secondary-button"/>
														</style>
													</object>
												</child>
											</object>
										</child>

										<child>
											<object class="GtkLabel" id="status_label">
												<property name="xalign">0</property>
												<property name="yalign">0.5</property>
												<property name="hexpand">true</property>
												<property name="wrap">true</property>
												<style>
													<class name="status-label"/>
												</style>
											</object>
										</child>
									</object>
								</child>
							</object>
						</child>

						<child>
							<!-- Bottom utility strip -->
							<object class="GtkBox" id="power_strip">
								<property name="orientation">horizontal</property>
								<property name="halign">end</property>
								<property name="valign">end</property>
								<property name="hexpand">true</property>
								<property name="spacing">10</property>
								<style>
									<class name="power-strip"/>
								</style>

								<child>
									<object class="GtkLabel" id="keyboard_label">
										<property name="visible">false</property>
										<property name="valign">center</property>
										<style>
											<class name="keyboard-indicator"/>
										</style>
									</object>
								</child>

								<child>
									<object class="GtkButton" id="suspend_button">
										<property name="label">⏾</property>
										<property name="tooltip-text" translatable="yes">Suspend</property>
										<style>
											<class name="secondary-button"/>
											<class name="power-button"/>
										</style>
									</object>
								</child>

								<child>
									<object class="GtkButton" id="hibernate_button">
										<property name="label">❄</property>
										<property name="tooltip-text" translatable="yes">Hibernate</property>
										<style>
											<class name="secondary-button"/>
											<class name="power-button"/>
										</style>
									</object>
								</child>

								<child>
									<object class="GtkButton" id="reboot_button">
										<property name="label">↻</property>
										<property name="tooltip-text" translatable="yes">Reboot</property>
										<style>
											<class name="secondary-button"/>
											<class name="power-button"/>
										</style>
									</object>
								</child>

								<child>
									<object class="GtkButton" id="quit_button">
										<property name="label">⏻</property>
										<property name="tooltip-text" translatable="yes">Power off</property>
										<style>
											<class name="secondary-button"/>
											<class name="power-button"/>
										</style>
									</object>
								</child>
							</object>
						</child>
					</object>
				</child>
			</object>
		</child>
	</object>
</interface>
