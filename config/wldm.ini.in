#
# Main daemon settings.
# These options control the privileged wldm process.
#
[daemon]
# Seat identifier exported into the user session environment.
seat = seat0

# Optional daemon log file. Leave empty to keep logging on stderr/journal.
log-path =

# Commands exposed through the greeter power menu.
poweroff-command = poweroff
reboot-command = reboot

# Leave empty to disable the action and hide its button in the greeter.
suspend-command =
hibernate-command =

#
# Greeter process settings.
# The daemon starts the compositor and GTK greeter under this unprivileged
# account.
#
[greeter]
# User and group for the greeter process.
user = @greeter_user@
group = @greeter_group@

# Virtual terminal reserved for the greeter.
tty = 7

# Directory that contains wldm runtime assets such as resources/ and themes/.
data-dir = @datadir@

# Directory that contains locale catalogs used by the greeter.
locale-dir = @localedir@

# Optional directory for small greeter-managed state such as the last restored
# username/session choice. Leave empty to disable persistent greeter state.
state-dir =

# Theme name. "default" uses the built-in resources directory.
theme = default

# Colon-separated directories scanned for system session .desktop files.
session-dirs = /usr/share/wayland-sessions

# Per-user session directory relative to the typed user's home directory.
user-session-dir = .local/share/wayland-sessions

# Compositor launcher prefix. wldm appends "wldm greeter" automatically.
command = cage -d -s --

# PAM service used for the greeter session itself.
pam-service = system-login

# How many consecutive greeter crashes are tolerated before the daemon stops.
max-restarts = 3

# If enabled, also scan the typed user's session directory after a username is
# entered.
user-sessions = yes

# Optional stderr log for the greeter process.
log-path =

#
# Final user session settings.
# These options control how wldm opens the authenticated user's real desktop
# session after login succeeds.
#
[session]
# PAM service used for the final user session.
pam-service = login

# Optional wrapper executable used to launch the chosen session command.
# Packaging rewrites this path to match the installation prefix.
# Set an empty value to exec the session command directly.
execute = @datadir@/scripts/wayland-session

# Optional helper executable run after PAM/session setup but before the final
# session command starts. A non-zero exit status aborts startup.
pre-execute =

# Optional helper executable run after the user session exits and before PAM
# cleanup finishes. A non-zero exit status is only logged.
post-execute =

#
# Optional D-Bus adapter settings.
# The daemon can start a separate unprivileged adapter process that mirrors
# daemon state to D-Bus without moving D-Bus code into the privileged path.
#
[dbus]
# Enable the optional adapter process.
enabled = no

# User account used to run the adapter process.
# If you change this value, update the installed D-Bus policy file as well:
# /usr/share/dbus-1/system.d/wldm-dbus.conf
user = @dbus_user@

# Well-known D-Bus service name exported by the adapter.
service = @dbus_service@

# Optional log file for the adapter process. Leave empty to keep logging on
# stderr/journal.
log-path =

#
# Keyboard defaults for the greeter compositor.
# wldm exports these values as XKB_DEFAULT_* so cage or another compositor can
# apply them.
#
[keyboard]
# XKB rules name, for example "evdev".
rules = evdev

# XKB keyboard model, for example "pc105".
model = pc105

# Comma-separated keyboard layouts, for example "us,ru".
layout = us

# Comma-separated layout variants matching the layout list, for example
# ",winkeys" or "intl,".
variant =

# Comma-separated XKB options, for example "grp:alt_shift_toggle" or
# "compose:ralt".
options = grp:alt_shift_toggle
